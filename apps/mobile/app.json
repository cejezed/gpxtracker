{
  "expo": {
    "name": "RallyTrail",
    "slug": "rallytrail",
    "scheme": "rallytrail",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brikx.rallytrail",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RallyTrail gebruikt je locatie om je positie op de route en in je live groep te tonen."
      }
    },
    "android": {
      "package": "com.brikx.rallytrail",
      "versionCode": 6,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RallyTrail gebruikt je locatie om je positie op de route en in je live groep te tonen."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f47c9e15-6ef1-4bc0-ae3d-0271d474d6cd"
      }
    },
    "owner": "cejezed"
  }
}
